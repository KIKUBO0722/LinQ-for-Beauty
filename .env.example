# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# LINE Messaging API
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# Anthropic (Phase 2)
ANTHROPIC_API_KEY=

# Auth
JWT_SECRET=
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ICS feed (Day 7-9)
# Generate with: openssl rand -hex 32
ICS_SECRET=
# Base URL used when generating ICS subscription URLs. Defaults to http://localhost:3333.
ICS_BASE_URL=http://localhost:3333

# Redis (BullMQ — Day 10-12)
# Start with: docker run -d -p 6379:6379 --name linq-redis redis:alpine
REDIS_HOST=localhost
REDIS_PORT=6379

# App
API_PORT=3001
WEB_PORT=3000
NODE_ENV=development
